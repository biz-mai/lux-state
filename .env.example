# ─────────────────────────────────────────────────────────────
# LuxEstate PH — Environment Variables
# Copy this file to .env.local for local dev (never commit it!)
# Add these same keys in Vercel → Project Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# The Gmail address you use to send emails FROM
GMAIL_USER=yourgmail@gmail.com

# Gmail App Password (NOT your real Gmail password)
# How to get it:
#   1. Go to myaccount.google.com → Security
#   2. Enable 2-Step Verification (required)
#   3. Search "App passwords" → Create one named "LuxEstate"
#   4. Copy the 16-character code (spaces don't matter)
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# Where lead notification emails are sent (your business email)
# Leave blank to use GMAIL_USER as the destination too
NOTIFY_EMAIL=leads@yourbusiness.com
